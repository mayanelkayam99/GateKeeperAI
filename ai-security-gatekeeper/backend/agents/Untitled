from sqlalchemy.orm import Session
from backend.models import CompanyPolicy  # ייבוא המודל שיצרנו בסעיף 1

# הפונקציה שלך עכשיו מקבלת db מהראוטר שהפעיל אותה
def analyze_package_legality(package_name: str, license_name: str, db: Session, llm_client):
    
    # 1. ניגשים ל-DB ושולפים את השורה הראשונה (והיחידה) של הפוליסי
    policy = db.query(CompanyPolicy).first()
    
    # 2. מגדירים ברירת מחדל (ליתר ביטחון, אם ה-DB עדיין ריק לגמרי)
    context = "We are a general technology company."
    allowed = ["MIT", "Apache-2.0"]
    blocked = ["GPL-3.0"]
    
    # 3. אם מצאנו פוליסי ב-DB, נחליף את ברירת המחדל בערכים הדינמיים שה-CISO שמר!
    if policy:
        context = policy.company_context
        allowed = policy.allowed_licenses  # מגיע כמערך פייתון רגיל: ['MIT', 'Apache-2.0']
        blocked = policy.blocked_licenses  # מגיע כמערך פייתון רגיל: ['GPL-3.0']

    # 4. עכשיו בונים את ה-Prompt ל-Groq ומזריקים פנימה את המשתנים הדינמיים
    system_prompt = f"""
    You are an expert DevSecOps Legal Compliance AI Agent. 
    Analyze the package '{package_name}' with license '{license_name}'.
    
    CRITICAL COMPLIANCE RULES TO ENFORCE:
    - Company Business Context: {context}
    - Approved Licenses List: {', '.join(allowed)}
    - Blocked Licenses List: {', '.join(blocked)}
    
    If the package license is in the blocked list, or if its terms violate the company business context, you must reply with 'BLOCKED'. 
    Use Chain of Thought to suggest a safe, modern alternative.
    """

    # 5. כאן מגיעה הקריאה הקיימת שלך ל-Groq
    response = llm_client.chat.completions.create(
        model="llama3-8b-8192",
        messages=[
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": f"Evaluate {package_name} ({license_name})"}
        ]
    )
    
    return response.choices[0].message.content